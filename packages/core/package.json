{
  "name": "@erikt/docgen",
  "version": "0.0.2",
  "type": "module",
  "bin": {
    "docgen": "./bin.ts"
  },
  "scripts": {
    "build": "tsdown src/index.ts --out-dir dist --dts"
  },
  "imports": {
    "#html": "./src/utils/html.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@shikijs/rehype": "catalog:",
    "minisearch": "catalog:",
    "rehype-slug": "catalog:",
    "rehype-stringify": "catalog:",
    "remark-gfm": "catalog:",
    "remark-frontmatter": "catalog:",
    "remark-parse": "catalog:",
    "remark-rehype": "catalog:",
    "unified": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  }
}
